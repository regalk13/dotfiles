[module/network]
type = internal/network
interface = enp6s0
interval = 1.0
label-connected = %{T3}Ôõô %downspeed%


label-disconnected = Ôõô Down 
label-disconnected-foreground = ${colors.fourth}
label-connected-foreground = ${colors.fourth}





[module/arch-updates]
type = custom/script 
exec = ~/.config/polybar/scripts/arch/updates.sh 
format = <label> 
label =  ÔĆÉ  %output% 
label-padding =1
label-background = ${colors.background}
label-foreground = ${colors.fourth}


[module/cpu]
type = internal/cpu
interval = 0.5

[module/memory]
type = internal/memory
interval = 3

[module/backlight]
type = internal/backlight
card = radeon_bl0

format = <label>
label = "ÔóĚ  %percentage%%"
label-foreground = ${colors.tertiary}


[module/wlan]
type = internal/network
interface = wlan0
interval = 3.0

format-connected = <label-connected>
format-connected-underline = #9f78e1
label-connected = "Ô™®"
label-connected-foreground = ${colors.primary}

format-disconnected = <label-disconnected>
format-disconnected-underline = ${self.format-connected-underline}
label-disconnected = Ô™©
label-disconnected-foreground = ${colors.alert}

; a = worst
ramp-signal-0 = a
ramp-signal-1 = b
ramp-signal-2 = c
ramp-signal-3 = d
ramp-signal-4 = e


[module/date]
type = internal/date
interval = 1

date =
date-alt = "%b %d, %Y  "
time = "%I:%M"
time-alt = "%H:%M:%S"

format-prefix-foreground = ${colors.foreground}
format-underline = #0a6cf5
label = %date%%time%







[module/audio]
type = internal/pulseaudio

format-volume = <ramp-volume>
label-volume-foreground = ${colors.fourth}
ramp-volume-foreground = ${colors.fourth}
label-volume =

