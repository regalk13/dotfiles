[colors]
#background = #fa1e2137
#added falcon bg color
background = #1E222A
background-2 = #303745
foreground = #e3eaf3
primary = #02c084
secondary = #65a2d9
tertiary = #d07ef2
fourth = #D2543B
alert = #ed404c



[bar/main]
width = 98%
offset-x = 20
offset-y = 9

height = 30
radius = 4.0

override-redirect = true
wm-restack = i3

background = ${colors.background}
foreground = ${colors.foreground}

padding-left = 1
padding-right = 2
module-margin-left = 2
module-margin-right = 1


tray-position = right

tray-detached = false

tray-maxsize = 15

tray-offset-x = 0

tray-offset-y = 0

tray-padding = 4

tray-scale = 1

tray-radius = 3

#enable IPC for play pause
enable-ipc = true


font-0 = Iosevka Nerd Font:bold:pixelsize=11:antialias=true;2.5
font-1 = Iosevka Nerd Font:style=Regular:pixelsize=17:antialias=true;3
font-2 = Iosevka Nerd Font:style=bold:pixelsize=11:antialias=true;3
font-3 = Iosevka Nerd Font:style=Regular:pixelsize=10:antialias=true;3
font-4 = Iosevka Nerd Font:style=Regular:pixelsize=16.5:antialias=true;3

modules-left = dmenu i3 
modules-right = arch-updates network  audio date powermenu

cursor-click = pointer
cursor-scroll = ns-resize


[module/xwindow]
type = internal/xwindow
label = %title:0:25:...%


[module/filesystem]
type = internal/fs
interval = 25111
mount-0 = /
label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground}

[module/dmenu]
type=custom/text
content=" Ô¨¶"
click-left= exec dmenu_run
content-foreground = ${colors.fourth}
content-alignment = left
content-font = 5


[module/i3]
type = internal/i3
pin-workspaces = false
strip-wsnumbers = true
index-sort = true
enable-click = true
enable-scroll = false
wrapping-scroll = false
reverse-scroll = false
fuzzy-match = true

ws-icon-default = "ÔĄĎ  "
ws-icon-0 = "0;0  "
ws-icon-1 = "1;%{T2}Óěē%{T-}  "
ws-icon-2 = "2;%{T2}ÓúĆ%{T-}  "
ws-icon-3 = "3;ÔČ©  "
ws-icon-4 = "4;ÔĀĽ  "
ws-icon-5 = "5;Óąó  "
ws-icon-6 = "6;6  "
ws-icon-7 = "7;7  "
ws-icon-8 = "8;8  "
ws-icon-9 = "9;ÔáĚ  "

format = <label-state>

label-focused = %icon%
label-focused-foreground = #D2543B
label-focused-padding = 1

label-unfocused = ${self.label-focused}
label-unfocused-foreground = #ABB2BF
label-unfocused-padding = ${self.label-focused-padding}

label-visible = ${self.label-focused}
label-visible-foreground = #0a7383
label-visible-padding = ${self.label-focused-padding}

label-urgent = ${self.label-focused}
label-urgent-foreground = ${colors.alert}
label-urgent-padding = ${self.label-focused-padding}


